{
  "buildCommand": "cd apps/web && pnpm db:push && pnpm build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/jobs/expire-pnrs",               "schedule": "0 2 * * *" },
    { "path": "/api/jobs/reconcile-pending-tickets", "schedule": "0 3 * * *" }
  ]
}
