rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ──────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // agencyId comes ONLY from the custom claim — never fall back to uid.
    // A user without the claim cannot access any tenant data.
    function myAgencyId() {
      return request.auth.token.agencyId;
    }

    function owns(agId) {
      return isSignedIn()
          && myAgencyId() != null
          && agId == myAgencyId();
    }

    // ── agencies ──────────────────────────────────────────────────────────────
    // Document ID = agencyId. Agencies are created by Admin SDK only.
    match /agencies/{agId} {
      allow read:           if owns(agId);
      allow update:         if owns(agId);
      allow create, delete: if false;
    }

    // Sub-collections (e.g. agencies/{id}/config) — Cloud Functions only.
    match /agencies/{agId}/{sub=**} {
      allow read, write: if false;
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Any agency member may read all users in the same agency.
    // A user may update only their own document and only non-sensitive fields.
    // Creating / deleting user docs is done by Admin SDK / Cloud Functions.
    match /users/{userId} {
      allow read: if owns(resource.data.agencyId);

      allow update: if owns(resource.data.agencyId)
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasAny(['agencyId', 'role', 'isActive', 'createdAt']);

      allow create, delete: if false;
    }

    // ── bookings ──────────────────────────────────────────────────────────────
    match /bookings/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // Payments sub-collection written by Cloud Functions; client reads only.
    match /bookings/{bookingId}/payments/{payId} {
      allow read:  if owns(
                     get(/databases/$(database)/documents/bookings/$(bookingId))
                       .data.agencyId
                   );
      allow write: if false;
    }

    // ── customers ─────────────────────────────────────────────────────────────
    match /customers/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── invoices ──────────────────────────────────────────────────────────────
    // Created by Cloud Functions; client may read and update (e.g. mark sent).
    // Deletion blocked — invoices are permanent records.
    match /invoices/{id} {
      allow read, update: if owns(resource.data.agencyId);
      allow create:       if owns(request.resource.data.agencyId);
      allow delete:       if false;
    }

    // ── payments ──────────────────────────────────────────────────────────────
    match /payments/{id} {
      allow read, update: if owns(resource.data.agencyId);
      allow create:       if owns(request.resource.data.agencyId);
      allow delete:       if false;
    }

    // ── supplier_payments ─────────────────────────────────────────────────────
    // Immutable financial record — no edits or deletes after creation.
    match /supplier_payments/{id} {
      allow read:           if owns(resource.data.agencyId);
      allow create:         if owns(request.resource.data.agencyId);
      allow update, delete: if false;
    }

    // ── service_types ─────────────────────────────────────────────────────────
    match /service_types/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── suppliers ─────────────────────────────────────────────────────────────
    match /suppliers/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── employees ─────────────────────────────────────────────────────────────
    match /employees/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── departments ───────────────────────────────────────────────────────────
    match /departments/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── bank_accounts ─────────────────────────────────────────────────────────
    match /bank_accounts/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── bank_transactions ─────────────────────────────────────────────────────
    // Written by Cloud Functions only; client reads only.
    match /bank_transactions/{id} {
      allow read:  if owns(resource.data.agencyId);
      allow write: if false;
    }

    // ── cheques ───────────────────────────────────────────────────────────────
    match /cheques/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── exchange_rates ────────────────────────────────────────────────────────
    match /exchange_rates/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── chart_of_accounts ─────────────────────────────────────────────────────
    match /chart_of_accounts/{id} {
      allow read, update, delete: if owns(resource.data.agencyId);
      allow create:               if owns(request.resource.data.agencyId);
    }

    // ── journal_entries ───────────────────────────────────────────────────────
    // Append-only: قيود اليومية لا تُعدَّل ولا تُحذف أبداً.
    match /journal_entries/{id} {
      allow read:           if owns(resource.data.agencyId);
      allow create:         if owns(request.resource.data.agencyId);
      allow update, delete: if false;
    }

    // ── internal — Admin SDK / Cloud Functions only ───────────────────────────
    match /idempotency_keys/{id}       { allow read, write: if false; }
    match /invoice_counters/{id}       { allow read, write: if false; }
    match /zatca_submission_queue/{id} { allow read, write: if false; }

  }
}
