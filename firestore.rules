rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Falls back to uid when no agencyId custom claim (manually created users)
    function agencyId() {
      return request.auth.token.agencyId != null
        ? request.auth.token.agencyId
        : request.auth.uid;
    }

    function isAdmin() {
      return request.auth.token.role == 'admin';
    }

    function isSameAgency() {
      return resource.data.agencyId == agencyId();
    }

    function isSameAgencyCreate() {
      return request.resource.data.agencyId == agencyId();
    }

    // Permission gate: explicit claim OR admin role implicitly grants everything.
    function hasPerm(perm) {
      return request.auth.token[perm] == true || isAdmin();
    }

    // ─── agencies/{agencyId} ────────────────────────────────────────────────
    match /agencies/{agId} {
      allow read:  if isAuthenticated() && agId == agencyId();
      allow write: if isAuthenticated() && agId == agencyId();
    }

    // ─── bookings/{bookingId} ───────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read:   if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

    // ─── customers/{customerId} ─────────────────────────────────────────────
    match /customers/{customerId} {
      allow read:   if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

    // ─── invoices/{invoiceId} ───────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read:   if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

    // ─── payments/{paymentId} ───────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:   if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if false;
    }

    // ─── journal_entries/{entryId} ──────────────────────────────────────────
    match /journal_entries/{entryId} {
      allow read: if isAuthenticated()
                  && isSameAgency()
                  && hasPerm('perm_accounting_read');

      allow write: if false; // Cloud Functions (Admin SDK) only
    }

    // ─── idempotency_keys/{key} ─────────────────────────────────────────────
    match /idempotency_keys/{key} {
      allow read, write: if false;
    }

    // ─── invoice_counters/{agencyId} ────────────────────────────────────────
    match /invoice_counters/{agId} {
      allow read, write: if false;
    }

    // ─── service_types/{typeId} ─────────────────────────────────────────────
    match /service_types/{typeId} {
      allow read:   if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

    // ─── suppliers/{supplierId} ─────────────────────────────────────────────
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

    // ─── employees/{employeeId} ─────────────────────────────────────────────
    match /employees/{employeeId} {
      allow read: if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

    // ─── chart_of_accounts/{accountId} ─────────────────────────────────────
    match /chart_of_accounts/{accountId} {
      allow read: if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

    // ─── currencies/{currencyId} ────────────────────────────────────────────
    match /currencies/{currencyId} {
      allow read: if isAuthenticated() && isSameAgency();
      allow create: if isAuthenticated() && isSameAgencyCreate();
      allow update: if isAuthenticated() && isSameAgency() && isSameAgencyCreate();
      allow delete: if isAuthenticated() && isSameAgency() && isAdmin();
    }

  }
}
