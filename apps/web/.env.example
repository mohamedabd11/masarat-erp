# ─── Neon Postgres ────────────────────────────────────────────────────────────
# From: Neon Console → your project → Connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ─── Firebase (Auth only) ─────────────────────────────────────────────────────
# From: Firebase Console → Project Settings → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# From: Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON content as a single string (no newlines)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── App ──────────────────────────────────────────────────────────────────────
# Super-admin email: can activate/suspend agencies via /api/admin/action
SUPER_ADMIN_EMAIL=

# Required: secret token for the /api/setup-db endpoint (sent as x-setup-secret header)
SETUP_SECRET=
# Required: secret token for the /api/jobs/* cron endpoints (sent as Bearer token)
CRON_SECRET=

# Production: https://your-domain.com  |  Development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional ─────────────────────────────────────────────────────────────────
# Set to "true" to show the Firestore→Postgres migration tool in the accounting page
NEXT_PUBLIC_SHOW_MIGRATION_TOOL=false

# Set to "true" to connect Firebase Auth to local emulator (port 9099)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
