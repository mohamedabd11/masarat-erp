# =============================================================================
# Masarat ERP — Environment Variables
# =============================================================================
# نسخ هذا الملف إلى .env.local ثم ملء القيم
# لا ترفع .env.local إلى git أبداً

# =============================================================================
# DATABASE (Neon PostgreSQL) — الإعداد الأساسي
# =============================================================================
# احصل على هذه القيمة من: neon.tech → Project → Connection Details
# استخدم "Connection string" مع ?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/masarat?sslmode=require

# =============================================================================
# FIREBASE AUTH — يبقى للمصادقة فقط
# =============================================================================
# احصل على هذه القيم من: Firebase Console → Project Settings → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# تطوير: اتصل بـ Firebase Emulator
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# =============================================================================
# FIREBASE ADMIN SDK — Server-side only (لا تُكشف للمتصفح)
# =============================================================================
# احصل على هذه القيمة من: Firebase Console → Project Settings → Service Accounts
# الصيغة: JSON كامل في سطر واحد
FIREBASE_SERVICE_ACCOUNT_JSON=

# =============================================================================
# SUPER ADMIN — Server-side ONLY
# =============================================================================
# تحذير: لا تستخدم NEXT_PUBLIC_ لهذا المتغير أبداً
# يُستخدم فقط في Server Actions وAPI Routes
SUPER_ADMIN_EMAIL=admin@masaraterp.sa

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# ZATCA — E-Invoice Configuration
# =============================================================================
ZATCA_ENVIRONMENT=simulation
# simulation | production
# ZATCA_API_URL يُحدَّد تلقائياً بناءً على البيئة

# =============================================================================
# OBJECT STORAGE — لتخزين ملفات XML الموقعة و PDF الفواتير
# =============================================================================
# يمكن استخدام Vercel Blob أو AWS S3 أو Cloudflare R2
BLOB_READ_WRITE_TOKEN=

# =============================================================================
# MONITORING (اختياري في التطوير، إلزامي في الإنتاج)
# =============================================================================
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================================
# RATE LIMITING — Upstash Redis (اختياري)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
