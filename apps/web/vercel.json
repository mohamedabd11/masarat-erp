{
  "installCommand": "cd ../.. && npx pnpm@9 install",
  "buildCommand": "cd ../.. && npx pnpm@9 --filter @masarat/web build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/jobs/expire-pnrs",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/jobs/reconcile-pending-tickets",
      "schedule": "30 * * * *"
    }
  ]
}
